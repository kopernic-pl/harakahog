should render Haraka deployment matching snapshot:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: harakahog
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harakahog-haraka
      name: harakahog-haraka
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/name: harakahog-haraka
      template:
        metadata:
          labels:
            app.kubernetes.io/name: harakahog-haraka
        spec:
          containers:
            - env:
                - name: HARAKA_LOG_LEVEL
                  value: info
                - name: APK_INSTALL_PACKAGES
                  value: openssl
              image: instrumentisto/haraka:3.0.3
              imagePullPolicy: IfNotPresent
              name: haraka
              ports:
                - containerPort: 5870
                  name: smtp
                  protocol: TCP
              volumeMounts:
                - mountPath: /etc/haraka/config
                  name: haraka-config
          initContainers:
            - command:
                - sh
                - -c
                - |
                  cp /h-config/* /config/
                  cp /tls-secret/* /config/
              image: busybox:1.36
              name: init-config
              volumeMounts:
                - mountPath: /h-config
                  name: h-config
                  readOnly: true
                - mountPath: /tls-secret
                  name: tls-secret
                  readOnly: true
                - mountPath: /config
                  name: haraka-config
          volumes:
            - configMap:
                name: harakahog-haraka-config
              name: h-config
            - name: tls-secret
              secret:
                secretName: harakahog-haraka-tls
            - emptyDir: {}
              name: haraka-config
should render MailHog deployment matching snapshot:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: harakahog
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harakahog-mailhog
      name: harakahog-mailhog
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/name: harakahog-mailhog
      template:
        metadata:
          labels:
            app.kubernetes.io/name: harakahog-mailhog
        spec:
          containers:
            - image: mailhog/mailhog:v1.0.1
              imagePullPolicy: IfNotPresent
              name: mailhog
              ports:
                - containerPort: 1025
                  name: smtp
                  protocol: TCP
                - containerPort: 8025
                  name: http
                  protocol: TCP
