should render all resources with default values:
  1: |
    apiVersion: v1
    data:
      auth_flat_file.ini: |
        [core]
        methods=LOGIN
        [users]

        admin@example.org=admin123
      log.ini: |
        [main]
        level=info
        timestamps=false
        format=default
      plugins: |
        relay
        tls
        auth/flat_file
        queue/smtp_forward
      relay.ini: |
        [relay]
        acl=true
        force_routing=true
        dest_domains=true
      relay_acl_allow: |
        127.0.0.1/32
        192.168.65.1/32
      relay_dest_domains.ini: |
        [domains]
        any = {"action":"continue","nexthop":"harakahog-mailhog.NAMESPACE.svc.cluster.local:1025"}
      smtp.ini: |
        listen=[::0]:5870
        [headers]
        max_lines=1000
        max_received=100
      tls.ini: |
        key=tls_key.pem
        cert=tls_cert.pem
        minVersion=TLSv1.2
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: harakahog
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harakahog-haraka
      name: harakahog-haraka-config
  2: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: harakahog
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harakahog-haraka
      name: harakahog-haraka
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/name: harakahog-haraka
      template:
        metadata:
          labels:
            app.kubernetes.io/name: harakahog-haraka
        spec:
          containers:
            - env:
                - name: HARAKA_LOG_LEVEL
                  value: info
                - name: APK_INSTALL_PACKAGES
                  value: openssl
              image: instrumentisto/haraka:3.0.3
              imagePullPolicy: IfNotPresent
              name: haraka
              ports:
                - containerPort: 5870
                  name: smtp
                  protocol: TCP
              volumeMounts:
                - mountPath: /etc/haraka/config
                  name: haraka-config
          initContainers:
            - command:
                - sh
                - -c
                - |
                  cp /h-config/* /config/
                  cp /tls-secret/* /config/
              image: busybox:1.36
              name: init-config
              volumeMounts:
                - mountPath: /h-config
                  name: h-config
                  readOnly: true
                - mountPath: /tls-secret
                  name: tls-secret
                  readOnly: true
                - mountPath: /config
                  name: haraka-config
          volumes:
            - configMap:
                name: harakahog-haraka-config
              name: h-config
            - name: tls-secret
              secret:
                secretName: harakahog-haraka-tls
            - emptyDir: {}
              name: haraka-config
  3: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: harakahog
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harakahog-haraka
      name: harakahog-haraka
    spec:
      ports:
        - name: smtp
          port: 5870
          protocol: TCP
          targetPort: smtp
      selector:
        app.kubernetes.io/name: harakahog-haraka
      type: ClusterIP
  4: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: harakahog
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harakahog-mailhog
      name: harakahog-mailhog
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/name: harakahog-mailhog
      template:
        metadata:
          labels:
            app.kubernetes.io/name: harakahog-mailhog
        spec:
          containers:
            - image: mailhog/mailhog:v1.0.1
              imagePullPolicy: IfNotPresent
              name: mailhog
              ports:
                - containerPort: 1025
                  name: smtp
                  protocol: TCP
                - containerPort: 8025
                  name: http
                  protocol: TCP
  5: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: harakahog
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: harakahog-mailhog
      name: harakahog-mailhog
    spec:
      ports:
        - name: smtp
          port: 1025
          protocol: TCP
          targetPort: smtp
        - name: http
          port: 8025
          protocol: TCP
          targetPort: http
      selector:
        app.kubernetes.io/name: harakahog-mailhog
      type: ClusterIP
