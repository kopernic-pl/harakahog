should listen on custom Haraka port:
  1: |
    auth_flat_file.ini: |
      [core]
      methods=LOGIN
      [users]

      admin@example.org=admin123
    log.ini: |
      [main]
      level=info
      timestamps=false
      format=default
    plugins: |
      relay
      tls
      auth/flat_file
      queue/smtp_forward
    relay.ini: |
      [relay]
      acl=true
      force_routing=true
      dest_domains=true
    relay_acl_allow: |
      127.0.0.1/32
      192.168.65.1/32
    relay_dest_domains.ini: |
      [domains]
      any = {"action":"continue","nexthop":"harakahog-mailhog.NAMESPACE.svc.cluster.local:1025"}
    smtp.ini: |
      listen=[::0]:2525
      [headers]
      max_lines=1000
      max_received=100
    tls.ini: |
      key=tls_key.pem
      cert=tls_cert.pem
      minVersion=TLSv1.2
